# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/test-results
/playwright-report
/playwright/.cache

# lighthouse CI
/.lighthouseci/

# next.js
/.next/
/out/

# production
/build

# service worker build artifact
/public/sw.js
/public/sw.js.map

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.envrc

# playwright MCP screenshots
.playwright-mcp/

# crash dumps
*.stackdump

# pnpm store (created in Docker environments)
.pnpm-store/

# Windows
Thumbs.db
nul

# claude local settings
.claude/settings.local.json
.claude/session-logs/
storybook-static

# test artifacts
contrast-audit-output.txt
e2e/__snapshots__/
