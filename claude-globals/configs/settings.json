{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash(ls:*)",
      "Bash(pnpm lint:css:*)",
      "Bash(pnpm lint:*)",
      "Bash(pnpm typecheck:*)",
      "Bash(pnpm build:*)"
    ],
    "defaultMode": "default"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node C:/Users/minkk/.claude/hooks/pre-session-cleanup.js",
            "timeout": 10
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"C:/Users/minkk/.claude/hooks/gsd-check-update.js\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"C:/Users/minkk/.claude/hooks/gsd-context-monitor.js\""
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash C:/Users/minkk/.claude/CoWork/Anatta-Project/statusline.sh"
  },
  "enabledPlugins": {
    "code-simplifier@claude-plugins-official": false,
    "feature-dev@claude-plugins-official": false,
    "code-review@claude-plugins-official": false,
    "commit-commands@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": false,
    "playwright@claude-plugins-official": false,
    "pr-review-toolkit@claude-plugins-official": false,
    "vercel@claude-plugins-official": false,
    "stripe@claude-plugins-official": false,
    "agent-sdk-dev@claude-plugins-official": false,
    "frontend-design@claude-plugins-official": false,
    "context7@claude-plugins-official": true,
    "supabase@claude-plugins-official": false,
    "explanatory-output-style@claude-plugins-official": false,
    "plugin-dev@claude-plugins-official": false,
    "hookify@claude-plugins-official": false,
    "learning-output-style@claude-plugins-official": true,
    "sentry@claude-plugins-official": false,
    "github@claude-plugins-official": false,
    "postgres-best-practices@supabase-agent-skills": false
  },
  "autoUpdatesChannel": "latest",
  "skipDangerousModePermissionPrompt": true
}
