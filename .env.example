# ===========================================
# Mandalay Morning Star - Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values
# DO NOT commit .env.local to version control

# -------------------------------------------
# Supabase Configuration (Required)
# -------------------------------------------
# Get these from: https://app.supabase.com/project/_/settings/api

NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role key - NEVER expose this in client-side code
# Used for server-side operations that bypass RLS
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# -------------------------------------------
# Google Maps Configuration (Required)
# -------------------------------------------
# Enable these APIs in Google Cloud Console:
# - Geocoding API
# - Routes API (or Distance Matrix API)
# Get your key from: https://console.cloud.google.com/apis/credentials

GOOGLE_MAPS_API_KEY=AIza...

# -------------------------------------------
# Stripe Configuration (Required for Payments)
# -------------------------------------------
# Get these from: https://dashboard.stripe.com/test/apikeys
# Use TEST keys for development (start with sk_test_ and pk_test_)

STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Webhook secret for verifying Stripe events
# Get this when setting up a webhook endpoint or use:
# `stripe listen --forward-to localhost:3000/api/webhooks/stripe`
STRIPE_WEBHOOK_SECRET=whsec_...

# -------------------------------------------
# Email Configuration (Required for Notifications)
# -------------------------------------------
# Transactional emails via Resend + React Email
# Get your API key from: https://resend.com/api-keys
# Verify domain mail.mandalaymorningstar.com in Resend Dashboard > Domains

RESEND_API_KEY=re_...

# Resend webhook secret for delivery tracking (optional)
# Set up at: Resend Dashboard > Webhooks > Add Webhook
# URL: https://your-app.vercel.app/api/webhooks/resend
# Events: email.delivered, email.opened, email.clicked, email.bounced, email.complained
RESEND_WEBHOOK_SECRET=whsec_...

# -------------------------------------------
# Cron Configuration (Optional)
# -------------------------------------------
# Secures /api/cron/* endpoints (delivery reminders, etc.)
# Set any random string. Vercel sends it automatically via cron config.
CRON_SECRET=your_random_secret_here

# -------------------------------------------
# Sentry Configuration (Required for Error Tracking)
# -------------------------------------------
# Get your DSN from: https://sentry.io/settings/projects/{project}/keys/

NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.us.sentry.io/xxx

# Auth token for source maps upload (set in CI/CD, not locally)
# Create at: https://sentry.io/settings/auth-tokens/
SENTRY_AUTH_TOKEN=sntrys_...

# Enable debug mode to troubleshoot Sentry issues
# SENTRY_DEBUG=true

# -------------------------------------------
# Upstash Redis (Required for Rate Limiting)
# -------------------------------------------
# Provision via Vercel Dashboard -> Storage -> Create Database -> Upstash Redis
# Env vars are auto-populated when provisioned through Vercel Marketplace

UPSTASH_REDIS_REST_URL=https://...
UPSTASH_REDIS_REST_TOKEN=AX...

# -------------------------------------------
# Rate Limiting Configuration (Optional)
# -------------------------------------------
# All values have sensible defaults. Override to tune without redeploy.
# Format: MAX = integer, WINDOW = Upstash duration string (e.g., "1 m", "1 h", "30 s")

# RATE_LIMIT_AUTH_SIGNIN_MAX=5
# RATE_LIMIT_AUTH_SIGNIN_WINDOW=1 m
# RATE_LIMIT_AUTH_SIGNUP_MAX=3
# RATE_LIMIT_AUTH_SIGNUP_WINDOW=1 h
# RATE_LIMIT_API_WRITE_MAX=10
# RATE_LIMIT_API_WRITE_WINDOW=1 m
# RATE_LIMIT_PUBLIC_READ_MAX=60
# RATE_LIMIT_PUBLIC_READ_WINDOW=1 m
# RATE_LIMIT_DRIVER_LOCATION_MAX=2
# RATE_LIMIT_DRIVER_LOCATION_WINDOW=1 m
# RATE_LIMIT_DRIVER_ACTION_MAX=10
# RATE_LIMIT_DRIVER_ACTION_WINDOW=1 m
# RATE_LIMIT_CUSTOMER_MAX=30
# RATE_LIMIT_CUSTOMER_WINDOW=1 m
# RATE_LIMIT_ADMIN_MAX=120
# RATE_LIMIT_ADMIN_WINDOW=1 m
# RATE_LIMIT_GLOBAL_IP_MAX=120
# RATE_LIMIT_GLOBAL_IP_WINDOW=1 m

# -------------------------------------------
# Application Configuration (Optional)
# -------------------------------------------

# App URL - defaults to http://localhost:3000 in development
# Set to your production URL in production
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Operator phone number for driver "Call for Help" button
NEXT_PUBLIC_OPERATOR_PHONE=+16269001234

# -------------------------------------------
# Testing Configuration
# -------------------------------------------
# For local development testing, you can use these Stripe test values:
# - Test card: 4242 4242 4242 4242
# - Any future expiry date
# - Any 3-digit CVC
# - Any 5-digit ZIP

# To test webhooks locally, install Stripe CLI and run:
# stripe listen --forward-to localhost:3000/api/webhooks/stripe
